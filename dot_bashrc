#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
PS1='[\u@\h \W]\$ '


# Source all scripts in ~/.bashrc.d/
if [ -d "$HOME/.bashrc.d" ]; then
  for file in "$HOME/.bashrc.d/"*.sh; do
    [ -r "$file" ] && . "$file"
  done
fi

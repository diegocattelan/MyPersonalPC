#!/bin/sh
set -eu

find_command() {
  cmd=$1

  if command -v "$cmd" >/dev/null 2>&1; then
    command -v "$cmd"
    return 0
  fi

  for candidate in "/usr/bin/$cmd" "/bin/$cmd" "/usr/sbin/$cmd" "/sbin/$cmd"; do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

is_physical_interface_linux() {
  iface=$1

  case "$iface" in
    lo|docker*|br-*|br[0-9]*|virbr*|veth*|tun*|tap*|wg*|tailscale*|zt*|cni*|flannel*|kube-ipvs*|dummy*)
      return 1
      ;;
  esac

  [ -e "/sys/class/net/$iface/device" ]
}

is_physical_interface_macos() {
  iface=$1

  case "$iface" in
    lo*|utun*|gif*|stf*|bridge*|awdl*|llw*|p2p*|vmenet*|vmnet*|tap*|tun*)
      return 1
      ;;
  esac

  if networksetup_cmd="$(find_command networksetup 2>/dev/null)"; then
    if "$networksetup_cmd" -listallhardwareports 2>/dev/null | awk -v iface="$iface" '
      $1 == "Device:" && $2 == iface {
        found = 1
      }
      END {
        exit(found ? 0 : 1)
      }
    '; then
      return 0
    fi
  fi

  case "$iface" in
    en[0-9]*|eth[0-9]*|wlan[0-9]*|wl[[:alnum:]]*|eno[0-9]*|ens[0-9]*|enp[0-9]*|wwan[0-9]*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

filter_ip_pairs_linux() {
  ips=$1
  out=""

  for pair in $ips; do
    iface=${pair%%=*}
    ipaddr=${pair#*=}
    [ "$iface" != "$pair" ] || continue

    if is_physical_interface_linux "$iface"; then
      if [ -n "$out" ]; then
        out="$out "
      fi
      out="$out$iface=$ipaddr"
    fi
  done

  [ -n "$out" ] || return 1
  printf '%s\n' "$out"
}

filter_ip_pairs_macos() {
  ips=$1
  out=""

  for pair in $ips; do
    iface=${pair%%=*}
    ipaddr=${pair#*=}
    [ "$iface" != "$pair" ] || continue

    if is_physical_interface_macos "$iface"; then
      if [ -n "$out" ]; then
        out="$out "
      fi
      out="$out$iface=$ipaddr"
    fi
  done

  [ -n "$out" ] || return 1
  printf '%s\n' "$out"
}

collect_ips_linux_all() {
  ip_cmd="$(find_command ip)" || return 1

  "$ip_cmd" -o -4 addr show scope global up 2>/dev/null | awk '
    {
      iface = $2
      sub(/@.*/, "", iface)
      ipaddr = ""
      for (i = 1; i <= NF; i++) {
        if ($i == "inet") {
          split($(i + 1), parts, "/")
          ipaddr = parts[1]
          break
        }
      }
      if (iface != "" && ipaddr != "") {
        if (out != "") {
          out = out " "
        }
        out = out iface "=" ipaddr
      }
    }
    END {
      if (out != "") {
        print out
      } else {
        exit 1
      }
    }
  '
}

collect_ips_linux() {
  ips="$(collect_ips_linux_all)" || return 1
  filter_ip_pairs_linux "$ips"
}

collect_ips_macos_all() {
  ifconfig_cmd="$(find_command ifconfig)" || return 1

  "$ifconfig_cmd" -a 2>/dev/null | awk '
    function flush() {
      if (iface != "" && ipaddr != "" && up && !loopback && active) {
        if (out != "") {
          out = out " "
        }
        out = out iface "=" ipaddr
      }
    }

    /^[[:alnum:]_.:-]+: flags=/ {
      flush()
      iface = $1
      sub(/:$/, "", iface)
      ipaddr = ""
      up = ($0 ~ /<[^>]*UP/)
      loopback = ($0 ~ /<[^>]*LOOPBACK/)
      active = 1
      next
    }

    /^[[:space:]]*status:/ {
      active = ($2 == "active")
      next
    }

    /^[[:space:]]*inet / {
      candidate = $2
      if (ipaddr == "" && candidate !~ /^127\./ && candidate !~ /^169\.254\./ && candidate != "0.0.0.0") {
        ipaddr = candidate
      }
    }

    END {
      flush()
      if (out != "") {
        print out
      } else {
        exit 1
      }
    }
  '
}

collect_ips_macos() {
  ips="$(collect_ips_macos_all)" || return 1
  filter_ip_pairs_macos "$ips"
}

collect_ips() {
  os="$(uname -s 2>/dev/null || printf unknown)"

  case "$os" in
    Darwin)
      collect_ips_macos
      ;;
    Linux)
      collect_ips_linux || collect_ips_macos
      ;;
    *)
      collect_ips_linux || collect_ips_macos
      ;;
  esac
}

format_link_segments() {
  ips="$(collect_ips)" || return 1
  [ -n "$ips" ] || return 1

  first=1
  for pair in $ips; do
    iface=${pair%%=*}
    ipaddr=${pair#*=}
    [ "$iface" != "$pair" ] || continue

    label=$(printf '%-8.8s' "$iface")
    if [ "$first" -eq 0 ]; then
      printf ' '
    fi
    first=0

    printf '\033[38;2;255;136;0m\033[0m'
    printf '\033[1;38;2;0;0;0;48;2;255;136;0m%s\033[0m' "$label"
    printf '\033[38;2;255;136;0m\033[0m'
    printf '\033[38;2;245;246;250m %s\033[0m' "$ipaddr"
  done

  [ "$first" -eq 0 ] || return 1
  printf '\n'
}

case "${1:-}" in
  --check)
    collect_ips >/dev/null
    exit $?
    ;;
  --plain)
    collect_ips
    ;;
  *)
    format_link_segments
    ;;
esac

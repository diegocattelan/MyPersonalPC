# Make Bash completion closer to Fish's interactive behavior.
set completion-ignore-case on
set show-all-if-ambiguous on
set show-all-if-unmodified on
set menu-complete-display-prefix on
set colored-stats on
set colored-completion-prefix on
set mark-symlinked-directories on

# Tab cycles completion candidates; Shift-Tab cycles backward.
"\t": menu-complete
"\e[Z": menu-complete-backward

# Search history entries that start with the current command prefix.
"\e[A": history-search-backward
"\e[B": history-search-forward

# Common terminal variants for Ctrl-Left / Ctrl-Right.
"\e[1;5D": backward-word
"\e[1;5C": forward-word
"\e[5D": backward-word
"\e[5C": forward-word
